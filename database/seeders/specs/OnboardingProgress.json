{
    "model": "OnboardingProgress",
    "table": "onboarding_progress",
    "fields": {
        "id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "user_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "step_key": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "completed_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        },
        "created_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        }
    },
    "relationships": {
        "user": {
            "type": "belongsTo",
            "model": "User"
        }
    },
    "value_hints": {
        "completed_at": {
            "type": "datetime",
            "example": "2024-01-01 00:00:00"
        },
        "created_at": {
            "type": "datetime",
            "example": "2024-01-01 00:00:00"
        }
    },
    "scenarios": []
}