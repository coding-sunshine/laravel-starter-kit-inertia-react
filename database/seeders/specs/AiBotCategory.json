            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "organization_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "name": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "slug": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "order_column": {
            "type": "integer",
            "nullable": true,
            "default": null
        },
        "created_at": {
            "type": "timestamptz",
            "nullable": true,
            "default": null
        },
        "updated_at": {
            "type": "timestamptz",
            "nullable": true,
            "default": null
        }
    },
    "relationships": {
        "promptCommands": {
