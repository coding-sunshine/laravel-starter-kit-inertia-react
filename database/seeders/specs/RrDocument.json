        "createdBy": {
            "type": "belongsTo",
            "model": "CreatedBy"
        },
        "updatedBy": {
            "type": "belongsTo",
            "model": "UpdatedBy"
        }
    },
    "value_hints": {
        "rr_received_date": {
            "type": "datetime",
            "example": "2024-01-01 00:00:00"
        },
        "has_discrepancy": {
            "type": "boolean",
            "example": true
        }
    },
    "scenarios": []
