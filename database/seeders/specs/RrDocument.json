            "default": null
        },
        "rake_id": {
            "type": "integer",
            "nullable": true,
            "default": null
        },
        "rr_number": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "rr_received_date": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        },
        "rr_weight_mt": {
            "type": "numeric",
            "nullable": true,
            "default": null
        },
        "rr_details": {
            "type": "text",
            "nullable": true,
            "default": null
        },
        "document_status": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "has_discrepancy": {
            "type": "boolean",
            "nullable": true,
            "default": null
        },
        "discrepancy_details": {
            "type": "text",
            "nullable": true,
            "default": null
        },
        "created_by": {
            "type": "integer",
            "nullable": true,
            "default": null
        },
        "created_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        },
        "updated_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        },
        "updated_by": {
            "type": "integer",
            "nullable": true,
            "default": null
        },
        "fnr": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "from_station_code": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "to_station_code": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "freight_total": {
            "type": "numeric",
            "nullable": true,
            "default": null
        }
    },
    "relationships": {
