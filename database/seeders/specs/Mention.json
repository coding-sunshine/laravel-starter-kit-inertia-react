{
    "model": "Mention",
    "table": "mentions",
    "fields": {
        "id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "mentionable_type": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "mentionable_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "mentioned_user_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "mentioned_by_user_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "context": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "notified_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        },
        "organization_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "created_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        },
        "updated_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        }
    },
    "relationships": {
        "mentionedUser": {
            "type": "belongsTo",
            "model": "MentionedUser"
        },
        "mentionedByUser": {
            "type": "belongsTo",
            "model": "MentionedByUser"
        },
        "organization": {
            "type": "belongsTo",
            "model": "Organization"
        }
    },
    "value_hints": {
        "notified_at": {
            "type": "datetime",
            "example": "2024-01-01 00:00:00"
        }
    }
}