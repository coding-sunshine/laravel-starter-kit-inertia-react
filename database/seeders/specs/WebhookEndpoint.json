        }
    },
    "value_hints": {
        "is_active": {
            "type": "boolean",
            "example": true
        },
        "last_triggered_at": {
            "type": "datetime",
            "example": "2024-01-01 00:00:00"
        },
        "url": {
            "type": "url",
            "example": "https://example.com"
        }
    }
}