{
    "model": "BuilderEmailLog",
    "table": "builder_email_logs",
    "fields": {
        "id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "organization_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "contact_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "project_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "sent_by": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "template_type": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "recipient_email": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "recipient_name": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "subject": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "payload": {
            "type": "json",
            "nullable": true,
            "default": null
        },
        "status": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "created_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        },
        "updated_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        }
    },
    "relationships": {
        "contact": {
            "type": "belongsTo",
            "model": "Contact"
        },
        "project": {
            "type": "belongsTo",
            "model": "Project"
        },
        "sentByUser": {
            "type": "belongsTo",
            "model": "SentByUser"
        },
        "organization": {
            "type": "belongsTo",
            "model": "Organization"
        }
    },
    "value_hints": {
        "recipient_email": {
            "type": "email",
            "example": "user@example.com"
        },
        "recipient_name": {
            "type": "name",
            "example": "John Doe"
        }
    }
}