{
    "model": "Questionnaire",
    "table": "questionnaires",
    "fields": {
        "id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "organization_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "contact_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "title": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "answers": {
            "type": "json",
            "nullable": true,
            "default": null
        },
        "created_at": {
            "type": "timestamptz",
            "nullable": true,
            "default": null
        },
        "updated_at": {
            "type": "timestamptz",
            "nullable": true,
            "default": null
        }
    },
    "relationships": {
        "contact": {
            "type": "belongsTo",
            "model": "Contact"
        },
        "surveyQuestions": {
            "type": "hasMany",
            "model": "SurveyQuestion"
        },
        "organization": {
            "type": "belongsTo",
            "model": "Organization"
        }
    },
    "value_hints": [],
    "scenarios": []
}