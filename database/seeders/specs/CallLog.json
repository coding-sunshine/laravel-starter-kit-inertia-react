{
    "model": "CallLog",
    "table": "call_logs",
    "fields": {
        "id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "contact_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "call_sid": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "direction": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "duration_seconds": {
            "type": "integer",
            "nullable": true,
            "default": null
        },
        "transcript": {
            "type": "text",
            "nullable": true,
            "default": null
        },
        "sentiment": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "outcome": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "vapi_metadata": {
            "type": "json",
            "nullable": true,
            "default": null
        },
        "called_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        },
        "created_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        },
        "updated_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
        }
    },
    "relationships": {
        "contact": {
            "type": "belongsTo",
            "model": "Contact"
        }
    },
    "value_hints": {
        "direction": {
            "type": "enum",
            "example": "inbound",
            "options": [
                "inbound",
                "outbound"
            ]
        },
        "sentiment": {
            "type": "enum",
            "example": "positive",
            "options": [
                "positive",
                "neutral",
                "negative"
            ]
        },
        "outcome": {
            "type": "enum",
            "example": "interested",
            "options": [
                "interested",
                "not-interested",
                "callback",
                "completed",
                "no-answer",
                "voicemail"
            ]
        },
        "called_at": {
            "type": "datetime",
            "example": "2024-01-01 00:00:00"
        }
    },
    "scenarios": []
}