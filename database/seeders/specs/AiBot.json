{
    "model": "AiBot",
    "table": "ai_bots",
    "fields": {
        "id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "category_id": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "name": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "slug": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "description": {
            "type": "text",
            "nullable": true,
            "default": null
        },
        "icon": {
            "type": "string",
            "nullable": true,
            "default": null
        },
        "is_system": {
            "type": "boolean",
            "nullable": true,
            "default": null
        },
        "is_active": {
            "type": "boolean",
            "nullable": true,
            "default": null
        },
        "created_by": {
            "type": "bigint",
            "nullable": true,
            "default": null
        },
        "created_at": {
            "type": "timestamp",
            "nullable": true,
            "default": null
