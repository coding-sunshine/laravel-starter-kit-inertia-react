APP_ENV=local
APP_KEY=
APP_DEBUG=true

# When true, sidebar shows only Fleet nav and /dashboard redirects to /fleet
FLEET_ONLY_APP=true

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Google Maps JavaScript API (Fleet: routes, trips, geofences, locations, EV charging). Restrict key by HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=

# Scout + Typesense (Laravel Herd includes Typesense; use these for local full-text search)
SCOUT_DRIVER=typesense
TYPESENSE_API_KEY=LARAVEL-HERD
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108

# AI: all models via OpenRouter (Fleet Assistant, RAG, vision, etc.). See docs/AI-PROVIDERS.md
OPENROUTER_API_KEY=
# Optional: only if you call OpenAI provider directly (we default to OpenRouter for everything)
# OPENAI_API_KEY=
