APP_ENV=local
APP_KEY=
APP_DEBUG=true

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Legacy MySQL (for Fusion CRM import: restore fv3_2026-03-02.sql then run php artisan fusion:import-contacts)
MYSQL_LEGACY_HOST=127.0.0.1
MYSQL_LEGACY_PORT=3306
MYSQL_LEGACY_DATABASE=fusioncrm
MYSQL_LEGACY_USERNAME=root
MYSQL_LEGACY_PASSWORD=

# AI — OpenRouter is the default gateway (proxies OpenAI, Anthropic, etc.)
AI_DEFAULT_PROVIDER=openrouter
OPENROUTER_API_KEY=

# Optional: direct provider keys (only needed if bypassing OpenRouter)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# COHERE_API_KEY=
