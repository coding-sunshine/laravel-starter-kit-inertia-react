            "Modules\\Changelog\\Database\\": "modules/changelog/database/",
            "Modules\\Announcements\\": "modules/announcements/src/",
            "Modules\\Announcements\\Database\\": "modules/announcements/database/",
            "Modules\\Blog\\": "modules/blog/src/",
            "Modules\\Blog\\Database\\": "modules/blog/database/",
            "Modules\\Gamification\\": "modules/gamification/src/",
            "Modules\\Gamification\\Database\\": "modules/gamification/database/",
            "Modules\\Reports\\": "modules/reports/src/",
            "Modules\\Reports\\Database\\": "modules/reports/database/",
