{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "nunomaduro/laravel-starter-kit-inertia-react",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "repositories": [
        {
            "name": "filament",
            "type": "composer",
            "url": "https://packages.filamentphp.com/composer"
        },
        {
            "type": "vcs",
            "url": "https://github.com/coding-sunshine/laravel-data-table"
        },
        {
            "type": "path",
            "url": "packages/beyondcode-laravel-vouchers"
        },
        {
            "type": "path",
            "url": "packages/jijunair-laravel-referral"
        },
        {
            "type": "path",
            "url": "packages/eznix86-laravel-ai-memory"
        },
        {
            "type": "path",
            "url": "packages/laravelcm-laravel-subscriptions"
        }
    ],
    "require": {
        "php": "^8.4.0",
        "a909m/filament-statefusion": "^2.3.0",
        "akaunting/laravel-money": "^6.0.3",
        "alizharb/filament-activity-log": "dev-main",
        "askedio/laravel-soft-cascade": "^13.0",
        "beyondcode/laravel-vouchers": "^2.3.1",
        "cjmellor/level-up": "^2.0",
        "dedoc/scramble": "^0.13.22",
        "devrabiul/laravel-geo-genius": "^1.6",
        "essa/api-tool-kit": "^3.3",
        "eznix86/laravel-ai-memory": "^1.0.2",
        "fakerphp/faker": "^1.24.1",
        "filament/filament": "^5.6.1",
        "filament/spatie-laravel-settings-plugin": "^5.6.1",
        "inertiajs/inertia-laravel": "^3.0.6",
        "jijunair/laravel-referral": "^1.0.5",
        "kalnoy/nestedset": "^7.0.1",
        "laravel/ai": "^0.6.5",
        "laravel/fortify": "^1.37.0",
        "laravel/framework": "^13.7",
        "laravel/horizon": "^5.46",
        "laravel/mcp": "^0.7",
        "laravel/pennant": "^1.23",
        "laravel/reverb": "^1.10.0",
        "laravel/sanctum": "^4.3.1",
        "laravel/scout": "^11.1",
        "laravel/slack-notification-channel": "^3.8",
        "laravel/tinker": "^3.0.2",
        "laravel/wayfinder": "^0.1.16",
        "laravelcm/laravel-subscriptions": "^1.8.1",
        "laraveldaily/laravel-invoices": "^4.2.0",
        "league/flysystem-aws-s3-v3": "^3.32",
        "lemonsqueezy/laravel": "^1.9.0",
        "machour/laravel-data-table": "dev-main",
        "martinpetricko/laravel-database-mail": "^2.0.3",
        "nunomaduro/essentials": "^1.2.0",
        "omaralalwi/laravel-taxify": "^2.0.4",
        "panphp/pan": "^0.1.10",
        "pgvector/pgvector": "^0.2.2",
        "prism-php/prism": "^0.100.1",
        "prism-php/relay": "^1.8",
        "pxlrbt/filament-excel": "^3.6.1",
        "saloonphp/saloon": "^4.0",
        "sentry/sentry-laravel": "^4.25.0",
        "spatie/browsershot": "^5.3.0",
        "spatie/eloquent-sortable": "^5.0.1",
        "spatie/laravel-activitylog": "^5.0",
        "spatie/laravel-analytics": "^5.7.1",
        "spatie/laravel-backup": "^10.2.1",
        "spatie/laravel-cookie-consent": "^3.4.0",
        "spatie/laravel-csp": "^3.23",
        "spatie/laravel-data": "^4.22.1",
        "spatie/laravel-honeypot": "^4.7.1",
        "spatie/laravel-medialibrary": "^11.22.0",
        "spatie/laravel-model-flags": "^1.5.0",
        "spatie/laravel-model-states": "^2.14.1",
        "spatie/laravel-pdf": "^2.8",
        "spatie/laravel-permission": "^7.4.1",
        "spatie/laravel-personal-data-export": "^4.3.2",
        "spatie/laravel-query-builder": "^7.2.1",
        "spatie/laravel-responsecache": "^8.3.1",
        "spatie/laravel-schemaless-attributes": "^2.6.0",
        "spatie/laravel-settings": "^3.8",
        "spatie/laravel-sitemap": "^8.1",
        "spatie/laravel-sluggable": "^4.0.1",
        "spatie/laravel-tags": "^4.11.0",
        "spatie/pdf-to-text": "^1.55",
        "stechstudio/filament-impersonate": "^5.3",
        "stephenjude/filament-feature-flags": "^5.0.4",
        "stripe/stripe-php": "^20.1",
        "typesense/typesense-php": "^6.0",
        "wildside/userstamps": "^4.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.3.0",
        "filament/blueprint": "^2.1.2",
        "larastan/larastan": "^3.9.6",
        "laravel/boost": "^2.4.6",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.29.1",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.6.3",
        "pestphp/pest-plugin-browser": "^4.3.1",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "rector/rector": "^2.4.2",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "bootstrap/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "bun install",
            "bun run build"
        ],
        "setup-blueprint": "bash scripts/setup-filament-blueprint.sh",
        "optimize-production": [
            "@php artisan config:cache",
            "@php artisan route:cache",
            "@php artisan filament:cache-components"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"bun run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan docs:sync || true",
            "@php artisan filament:upgrade"
        ],
        "post-install-cmd": [
            "@fix-referral-php84"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan clear",
            "@update:requirements",
            "@fix-referral-php84",
            "@php artisan boost:update --ansi || true",
            "@php artisan docs:sync || true"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "update:requirements": [
            "composer bump",
            "bunx npm-check-updates -u",
            "npm install"
        ],
        "lint": [
            "rector",
            "pint --parallel",
            "bun run lint"
        ],
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run",
            "bun run test:lint"
        ],
        "test:unit": "XDEBUG_MODE=\"coverage\" pest --parallel --coverage --exactly=100.0",
        "test:quick": "pest --parallel --compact",
        "test:types": [
            "phpstan",
            "bun run test:types"
        ],
        "test": "@test:quick",
        "test:full": [
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ],
        "fix-referral-php84": "php scripts/fix-referral-php84.php",
        "docs:check": "php artisan docs:sync --check",
        "docs:sync": "php artisan docs:sync",
        "docs:generate": "php artisan docs:sync --generate"
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "eznix86/laravel-ai-memory"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "cweagans/composer-patches": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
