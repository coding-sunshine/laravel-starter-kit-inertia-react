{
    "name": "eznix86/laravel-ai-memory",
    "description": "AI memory for Laravel AI SDK with semantic search and reranking",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "ai", "memory", "semantic-search", "vector-embeddings"],
    "authors": [
        {
            "name": "Bruno Bernard",
            "email": "contact.brunobernard@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/ai": "^0.3|^0.5"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "testcontainers/testcontainers": "^1.0",
        "ext-pdo_pgsql": "*",
        "rector/rector": "^2.3",
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.27"
    },
    "autoload": {
        "psr-4": {
            "Eznix86\\AI\\Memory\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eznix86\\AI\\Memory\\MemoryServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}
